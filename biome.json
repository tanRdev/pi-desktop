{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "off",
        "noArrayIndexKey": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off"
      }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!**/dist",
      "!!**/out",
      "!!**/coverage",
      "!!**/playwright-report",
      "!!**/test-results",
      "!!**/*.css"
    ]
  }
}
