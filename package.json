{
  "name": "pidesk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @pidesk/shared --filter @pidesk/agent-host --filter @pidesk/desktop dev",
    "format": "biome check --write .",
    "lint": "biome check .",
    "perf:bundle": "node scripts/perf-bundle.mjs",
    "perf:memory": "node scripts/perf-memory.mjs",
    "perf:startup": "node scripts/perf-startup.mjs",
    "test": "vitest run --config vitest.workspace.ts",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "effect": "^3.14.16",
    "@effect/platform": "^0.80.13",
    "@effect/platform-node": "^0.76.21",
    "playwright": "1.58.2",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
