{
  "name": "pi-desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "build": "bun run --workspaces build",
    "dev": "bun run --parallel --filter @pi-desktop/shared --filter @pi-desktop/agent-host --filter @pi-desktop/desktop dev",
    "format": "biome check --write .",
    "lint": "biome check .",
    "test": "bun x vitest run --config vitest.workspace.ts",
    "test:e2e": "bun run --filter @pi-desktop/desktop build && playwright test",
    "typecheck": "bun run --workspaces typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@effect/platform": "^0.80.13",
    "@effect/platform-node": "^0.76.21",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "effect": "^3.14.16",
    "jsdom": "^29.0.2",
    "playwright": "1.58.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "boneyard-js": "^1.7.6"
  }
}
