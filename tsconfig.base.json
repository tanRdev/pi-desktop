{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pi-desktop/contracts": ["packages/contracts/src/index.ts"],
      "@pi-desktop/contracts/*": ["packages/contracts/src/*"],
      "@pi-desktop/shared": ["packages/shared/src/index.ts"],
      "@pi-desktop/shared/*": ["packages/shared/src/*"],
      "@pi-desktop/agent-host": ["packages/agent-host/src/index.ts"],
      "@pi-desktop/agent-host/*": ["packages/agent-host/src/*"],
      "@pi-desktop/shell-model": ["packages/shell-model/src/index.ts"],
      "@pi-desktop/shell-model/*": ["packages/shell-model/src/*"],
      "@pi-desktop/ui": ["packages/ui/src/index.ts"],
      "@pi-desktop/ui/*": ["packages/ui/src/*"]
    }
  }
}
