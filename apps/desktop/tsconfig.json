{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@pidesk/shared": ["../../packages/shared/src/index.ts"],
      "@pidesk/shared/*": ["../../packages/shared/src/*"],
      "@pidesk/agent-host": ["../../packages/agent-host/src/index.ts"],
      "@pidesk/agent-host/*": ["../../packages/agent-host/src/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ]
}
