{
  "name": "@pi-desktop/desktop",
  "version": "0.4.0",
  "private": true,
  "productName": "Pi Desktop",
  "description": "Pi Desktop Electron desktop shell",
  "author": "Pi Desktop",
  "type": "module",
  "build": {
    "appId": "dev.pi.desktop",
    "productName": "Pi Desktop"
  },
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "dist:mac": "bun run build && bun ../../scripts/stage-desktop-release.mjs && electron-builder --projectDir . --config ../../electron-builder.yml --mac dmg zip --arm64",
    "postinstall": "electron-rebuild -f -w node-pty",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/source-code-pro": "^5.2.7",
    "@mariozechner/pi-coding-agent": "0.57.1",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@pi-desktop/agent-host": "workspace:*",
    "@pi-desktop/shared": "workspace:*",
    "@pi-desktop/shell-model": "workspace:*",
    "@pi-desktop/ui": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.0",
    "electron-updater": "^6.8.3",
    "marked": "^15.0.7",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grab": "^0.1.32",
    "react-markdown": "^9.0.3",
    "react-virtuoso": "^4.18.5",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "shiki": "^2.3.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "unicode-animations": "^1.0.3",
    "use-stick-to-bottom": "^1.1.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.0.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "8.0.0"
  }
}
