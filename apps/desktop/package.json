{
  "name": "@pidesk/desktop",
  "version": "0.1.0",
  "private": true,
  "productName": "PiDesk",
  "description": "PiDesk Electron desktop shell",
  "author": "PiDesk",
  "type": "module",
  "build": {
    "appId": "com.pidesk.desktop",
    "productName": "PiDesk",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir",
        "dmg",
        "zip"
      ]
    }
  },
  "main": "out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "postinstall": "electron-rebuild -f -w node-pty",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.57.1",
    "@monaco-editor/react": "^4.7.0",
    "@pidesk/agent-host": "workspace:*",
    "@pidesk/shared": "workspace:*",
    "@pidesk/shell-model": "workspace:*",
    "@pidesk/ui": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/core": "^3.20.3",
    "@tiptap/extension-mathematics": "^3.20.3",
    "@tiptap/extension-placeholder": "^3.20.3",
    "@tiptap/pm": "^3.20.3",
    "@tiptap/react": "^3.20.3",
    "@tiptap/starter-kit": "^3.20.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.474.0",
    "marked": "^15.0.7",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.33.5",
    "shiki": "^2.3.2",
    "tailwind-merge": "^2.6.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.0.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "8.0.0"
  }
}
